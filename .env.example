# MEDIA LUBUMBASHI — Variables d'environnement (copier vers .env, ne jamais commiter .env)

# Firebase (public — OK côté client Flutter)
FIREBASE_PROJECT_ID=membremedia
FIREBASE_API_KEY=your_web_api_key_here
FIREBASE_AUTH_DOMAIN=membremedia.firebaseapp.com
FIREBASE_STORAGE_BUCKET=membremedia.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# GitHub Actions (secrets GitHub uniquement — jamais dans le repo)
# FIREBASE_SERVICE_ACCOUNT=<JSON complet du compte de service>
# FIREBASE_PROJECT_ID=membremedia

# Supabase (optionnel)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
